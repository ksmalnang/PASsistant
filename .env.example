# Environment Configuration
# Copy this file to .env and fill in your actual values

# LLM Configuration
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_BASE_URL=https://api.openai.com/v1
EMBEDDING_MODEL=text-embedding-3-small
VECTOR_SIZE=1536

# GLM-4 OCR Configuration (Zhipu AI)
ZHIPU_API_KEY=your_zhipu_api_key_here
ZHIPU_BASE_URL=https://open.bigmodel.cn/api/paas/v4

# Qdrant Vector Database
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=your_qdrant_api_key_here
QDRANT_COLLECTION_NAME=student_documents
RETRIEVAL_STRATEGY=similarity
RERANKER_MODEL=jinaai/jina-reranker-v2-base-multilingual
RERANKER_BASE_URL=https://api.jina.ai/v1
RERANKER_API_KEY=your_reranker_api_key_here
RERANKER_CANDIDATE_MULTIPLIER=6

# Redis Cache
REDIS_URL=redis://localhost:6379/0
REDIS_KEY_PREFIX=student-records-chatbot
REDIS_CACHE_TTL_SECONDS=300

# LangSmith Configuration
LANGSMITH_TRACING=true
LANGSMITH_ENDPOINT=https://api.smith.langchain.com
LANGSMITH_API_KEY=your_langsmith_api_key_here
LANGSMITH_PROJECT=student-records-chatbot

# Application Configuration
APP_ENV=development
DEBUG=true
LOG_LEVEL=INFO
